{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "rangeStrategy": "bump",
  "rust": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackagePatterns": ["^tokio$", "^reqwest$"],
      "groupName": "async ecosystem"
    },
    {
      "matchPackagePatterns": ["^serde"],
      "groupName": "serialization"
    }
  ],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10
}
